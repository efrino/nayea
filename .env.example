VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server-only — never prefix with VITE_ (would get bundled into the client).
# From Supabase Dashboard > Project Settings > API > service_role key.
# Used by api/admin-list-users.js and api/admin-set-role.js for the
# superadmin User Management page. Keep this out of the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Shipping cost API (Komerce/RajaOngkir) — server-only, used in api/shipping-*.js
KOMERCE_API_KEY=your-komerce-api-key
KOMERCE_ORIGIN_ID=your-origin-district-id

# Resend (resend.com) — server-only, used in api/send-order-confirmation.js
# and api/send-shipping-notification.js. Optional: if unset, both endpoints
# no-op (return sent:false) instead of failing, so email is opt-in.
RESEND_API_KEY=your-resend-api-key

# Google Drive Picker — optional, powers the "Import Drive" button in
# Admin > Products/Banners (src/lib/googleDrivePicker.js). Both are public
# client identifiers restricted by authorized origin in Google Cloud
# Console, safe to expose in the client bundle. If unset, the button shows
# a clear "belum dikonfigurasi" error instead of crashing.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_GOOGLE_API_KEY=your-google-api-key
# Optional: restricts the picker to one Drive folder instead of the whole
# Drive. Value is the folder ID from its URL:
# https://drive.google.com/drive/folders/<FOLDER_ID>
VITE_GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
